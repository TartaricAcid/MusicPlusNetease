{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "music_plus:musician",
      "geometry": {
        "default": "geometry.music_plus_musician"
      },
      "materials": {
        "default": "entity_alphatest"
      },
      "render_controllers": ["controller.render.default"],
      "textures": {
        "default": "textures/music_plus/entity/musician"
      },
      "animations": {
        "riding_legs": "animation.music_plus.musician.riding_legs",
        "bob": "animation.player.bob"
      },
      "scripts": {
        "scale": "0.9375",
        "animate": [
          {
            "riding_legs": "query.is_riding"
          },
          {
            "bob": "!query.is_riding && !query.is_item_equipped('main_hand')"
          }
        ]
      },
      "enable_attachables": true
    }
  }
}
